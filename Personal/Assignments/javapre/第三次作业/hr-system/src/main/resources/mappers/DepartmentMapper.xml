<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hr.hrsystem.mapper.DepartmentMapper">

    <select id="selectById" parameterType="int" resultType="com.hr.hrsystem.entity.Department">
        select dept_id, dept_name, location
        from department
        where dept_id = #{deptId}
    </select>

</mapper>
