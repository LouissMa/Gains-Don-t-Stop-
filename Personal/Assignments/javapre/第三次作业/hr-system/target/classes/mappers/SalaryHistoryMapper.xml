<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hr.hrsystem.mapper.SalaryHistoryMapper">

    <select id="selectByEmpIdOrderByDateDesc" parameterType="int" resultType="com.hr.hrsystem.entity.SalaryHistory">
        select id, emp_id, old_salary, new_salary, adjust_date, reason
        from salary_history
        where emp_id = #{empId}
        order by adjust_date desc, id desc
    </select>

</mapper>
